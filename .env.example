# Contact form provider: emailjs (frontend-only) or api (serverless endpoint in /api/request-pricing.js)
VITE_CONTACT_FORM_PROVIDER=emailjs

# EmailJS (required when VITE_CONTACT_FORM_PROVIDER=emailjs)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_CONTACT_RECEIVER_EMAIL=support@qinsights.ai

# API endpoint (used only when VITE_CONTACT_FORM_PROVIDER=api)
VITE_CONTACT_FORM_API_ENDPOINT=/api/request-pricing
