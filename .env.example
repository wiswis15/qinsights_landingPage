# Contact form email delivery uses the serverless endpoint at /api/request-pricing.
# For local testing, run `pnpm dev:api` in one terminal and `pnpm dev` in another.

# Required SMTP settings for api/request-pricing.js.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional email settings.
DEFAULT_FROM_EMAIL=support@qinsights.ai
SUPPORT_TEAM_EMAILS=partnership@qinsights.ai

# Optional local API settings.
LOCAL_API_PORT=3001
LOCAL_API_URL=http://localhost:3001
