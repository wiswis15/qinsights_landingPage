{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "qinsights.ai"
        }
      ],
      "destination": "https://www.qinsights.ai/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [
        {
          "type": "host",
          "value": "qinsights.ai"
        }
      ],
      "destination": "https://www.qinsights.ai/:path*",
      "permanent": true
    }
  ]
}
